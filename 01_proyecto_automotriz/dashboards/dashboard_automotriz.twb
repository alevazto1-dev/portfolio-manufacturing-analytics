      <aliases enabled='yes' />
      <column caption='Scrap Rate %' datatype='real' name='[Calculation_1769941561524226]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([piezas_defectuosas])/SUM([piezas_producidas])*100' />
      </column>
      <column caption='Color Turno' datatype='string' name='[Calculation_1769941566398472]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [id_turno] = &quot;T03&quot; THEN &quot;Problema&quot; ELSE &quot;Normal&quot; END' />
      </column>
      <column caption='Disponibilidad' datatype='real' name='[Calculation_1769941596565513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([tiempo_operativo_min])/SUM([tiempo_planeado_min])' />
      </column>
      <column caption='Rendimiento' datatype='real' name='[Calculation_1769941596786698]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN(SUM([piezas_producidas])/SUM([piezas_planeadas]), 1.0)' />
      </column>
      <column caption='Calidad' datatype='real' name='[Calculation_1769941596991499]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([piezas_buenas])/SUM([piezas_producidas])' />
      </column>
      <column caption='OEE %' datatype='real' name='[Calculation_1769941597126668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1769941596565513]*[Calculation_1769941596786698]*[Calculation_1769941596991499]*100' />
      </column>
      <column caption='Color maquina' datatype='string' name='[Calculation_1769941597900813]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [id_maquina] = &quot;M03&quot; THEN &quot;Problema&quot; ELSE &quot;Normal&quot; END' />
